# ==============================================================================
# Enterprise Inventory & Supply Chain Management System - Root .gitignore
# ==============================================================================

# Node / Dependency Directories
node_modules/
**/node_modules/

# Package Lock files (if ignored locally, but recommended to keep at root/main project levels.
# We respect the server subfolder if it ignores it, but typically keep it for frontend)
# package-lock.json

# Build & Output Directories
dist/
**/dist/
dist-ssr/
**/dist-ssr/
build/
**/build/
out/
**/out/
.next/
**/.next/

# Test Coverage
coverage/
**/coverage/
.nyc_output/
**/.nyc_output/

# Logs and Diagnostics
logs/
**/logs/
*.log
**/*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Environment Variables & Secrets
.env
**/.env
.env.local
**/.env.local
.env.development.local
**/.env.development.local
.env.test.local
**/.env.test.local
.env.production.local
**/.env.production.local
.env.*.local
**/.env.*.local

# Allow committing environment templates
!.env.example
!**/.env.example

# OS Metadata
.DS_Store
.DS_Store?
._*
ehthumbs.db
Thumbs.db

# Editor & IDE Settings
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
.idea/
**/.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*~

# Database & Cache Files
*.db
*.sqlite
*.sqlite-journal
**/*.db
**/*.sqlite
**/*.sqlite-journal

# Project Specific Uploads & Temporary Directories
uploads/
**/uploads/
tmp/
**/tmp/
temp/
**/temp/
t.txt
**/t.txt
